# Base de données PostgreSQL (ex. Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# NextAuth — générer avec: openssl rand -base64 32
NEXTAUTH_SECRET="remplace-par-une-chaine-aleatoire-longue"
NEXTAUTH_URL="http://localhost:3000"

# Chiffrement des secrets (clés API IA) — générer avec: openssl rand -base64 32
APP_ENCRYPTION_KEY="remplace-par-une-chaine-aleatoire-longue"

# Envoi d'email (réinitialisation de mot de passe) via Resend — https://resend.com
# Sans ces variables, le lien de reset est affiché à l'écran en développement.
RESEND_API_KEY=""
EMAIL_FROM="onboarding@resend.dev"
